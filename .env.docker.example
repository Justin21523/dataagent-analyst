COMPOSE_PROJECT_NAME=dataagent-analyst

# Optional host ports. Leave blank or unset to let Docker allocate free ports.
FRONTEND_PORT=
BACKEND_PORT=
POSTGRES_PORT=
QDRANT_PORT=
QDRANT_GRPC_PORT=
LLM_PORT=

# Container images
PYTHON_IMAGE=python:3.12-slim-bookworm
NGINX_IMAGE=nginx:stable-alpine
POSTGRES_IMAGE=postgres:16-alpine
QDRANT_IMAGE=qdrant/qdrant:v1.18.1
CURL_IMAGE=curlimages/curl:8.12.1

# Backend
APP_ENV=docker
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=10
UVICORN_WORKERS=1
METADATA_BACKEND=postgres

# PostgreSQL
POSTGRES_DB=dataagent
POSTGRES_USER=dataagent
POSTGRES_PASSWORD=dataagent_dev_password

# Qdrant
QDRANT_API_KEY=
QDRANT_LOG_LEVEL=INFO

# Infrastructure status checks
INFRASTRUCTURE_CHECKS_ENABLED=true
INFRASTRUCTURE_TIMEOUT_SECONDS=3

# Local LLM
LLM_ENABLED=false
LLM_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLM_CUDA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLM_MODEL_FILE=model.gguf
LLM_MODEL_ALIAS=local-model
LLM_CONTEXT_SIZE=4096
LLM_THREADS=8
LLM_GPU_LAYERS=99
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# Model Explainability
EXPLAINABILITY_MAX_SAMPLE_SIZE=200
EXPLAINABILITY_MAX_BACKGROUND_SIZE=100
EXPLAINABILITY_MAX_PERMUTATION_REPEATS=20
EXPLAINABILITY_MAX_BEESWARM_FEATURES=15
EXPLAINABILITY_MAX_LOCAL_FEATURES=15
