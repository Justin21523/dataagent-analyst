APP_ENV=development
LOG_LEVEL=INFO

LLM_ENABLED=false
LLM_BASE_URL=http://127.0.0.1:8080
LLM_MODEL=qwen2.5-7b-instruct-q4_k_m-00001-of-00002.gguf
LLM_TIMEOUT_SECONDS=20
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=700

# Infrastructure
INFRASTRUCTURE_CHECKS_ENABLED=false
INFRASTRUCTURE_TIMEOUT_SECONDS=2
METADATA_BACKEND=json
DATABASE_URL=postgresql://dataagent:dataagent_dev_password@127.0.0.1:5432/dataagent
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# Model Explainability
EXPLAINABILITY_MAX_SAMPLE_SIZE=200
EXPLAINABILITY_MAX_BACKGROUND_SIZE=100
EXPLAINABILITY_MAX_PERMUTATION_REPEATS=20
EXPLAINABILITY_MAX_BEESWARM_FEATURES=15
EXPLAINABILITY_MAX_LOCAL_FEATURES=15
